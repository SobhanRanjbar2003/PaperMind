OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# اندازه هر chunk بر اساس کاراکتر
CHUNK_SIZE_CHARS=6000
CHUNK_OVERLAP_CHARS=300

# تعداد کلمات هدف برای خلاصه نهایی (تقریبا 10 صفحه)
TARGET_SUMMARY_WORDS=4500

# تعداد خلاصه هایی که در هر مرحله reduce با هم ادغام میشن
MAX_GROUP_SIZE=5

# timeout هر درخواست به Ollama بر حسب ثانیه
REQUEST_TIMEOUT=300
