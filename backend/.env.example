# --- اتصال به API مدل (مثلا سرور آروان، OpenAI-Compatible) ---
# آدرس Endpoint پایه؛ مسیر /chat/completions به صورت خودکار به انتهای آن اضافه می‌شود.
# مثال: اگر Endpoint کامل شما https://example.arvanai.ir/v1/chat/completions است،
# مقدار زیر را https://example.arvanai.ir/v1 قرار بده (بدون /chat/completions).
LLM_BASE_URL= 
LLM_API_KEY= 
LLM_MODEL= 

# حداکثر تعداد درخواست هم‌زمان به API (موازی‌سازی مرحله Map/Reduce)
LLM_MAX_CONCURRENCY=5

# تعداد تلاش مجدد در صورت خطای موقت (timeout/429/5xx) و backoff پایه (ثانیه)
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=1.5

# timeout هر درخواست به مدل (ثانیه)
REQUEST_TIMEOUT=120

# پارامترهای تولید متن
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=3000

# --- اندازه هر chunk بر اساس کاراکتر ---
CHUNK_SIZE_CHARS=6000
CHUNK_OVERLAP_CHARS=300

# تعداد کلمات هدف برای خلاصه نهایی (تقریبا 10 صفحه)
TARGET_SUMMARY_WORDS=4500

# تعداد خلاصه‌هایی که در هر مرحله reduce با هم ادغام می‌شوند
MAX_GROUP_SIZE=5

# =========================================================
# --- ساخت پاورپوینت (PPTX) از روی خلاصه ---
# =========================================================

# مدلی که برای طراحی ساختار اسلایدها استفاده می‌شود (خالی = همان LLM_MODEL)
PRESENTATION_LLM_MODEL=
PRESENTATION_LLM_MAX_TOKENS=6000
PRESENTATION_LLM_TEMPERATURE=0.4

# حداقل/حداکثر تعداد اسلاید محتوایی (بدون احتساب اسلاید عنوان/پایان)
PRESENTATION_MIN_SLIDES=8
PRESENTATION_MAX_SLIDES=16

# فونت فارسی که در فایل pptx استفاده می‌شود. باید روی سیستم بازکننده فایل نصب باشد.
PRESENTATION_FONT_FA=B Nazanin
PRESENTATION_FONT_FA_FALLBACK=Tahoma

# پوشه‌ای که فایل‌های pptx ساخته‌شده در آن ذخیره می‌شوند
PRESENTATION_OUTPUT_DIR=generated_presentations

# =========================================================
# --- ساخت Mind Map (نقشه‌ی ذهنی) از روی خلاصه + متن کتاب ---
# =========================================================

# مدلی که برای ساخت mind map استفاده می‌شود (خالی = همان LLM_MODEL)
MINDMAP_LLM_MODEL=
MINDMAP_LLM_MAX_TOKENS=4000
MINDMAP_LLM_TEMPERATURE=0.3

MINDMAP_MAX_DEPTH=5
MINDMAP_MAX_CHILDREN=5
MINDMAP_FIRST_PASS_DEPTH=3
MINDMAP_BRANCH_CONTEXT_CHARS=9000
MINDMAP_EXPAND_MAX_CONCURRENCY=5

# =========================================================
# تنظیمات سوال و جواب (Q&A)
# =========================================================

# مدل مخصوص تولید سوال (خالی بگذارید تا از LLM_MODEL استفاده شود)
QA_LLM_MODEL=

# تعداد پیش‌فرض سوال به ازای هر نوع
QA_DEFAULT_COUNT_MULTIPLE_CHOICE=10
QA_DEFAULT_COUNT_DESCRIPTIVE=5
QA_DEFAULT_COUNT_FILL_BLANK=10

# حداکثر سوال در یک درخواست
QA_MAX_COUNT=20
